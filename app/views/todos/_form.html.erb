<%= form_with(model: todo, class: "space-y-6") do |form| %>
  <% if todo.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(todo.errors.count, "error") %> prohibited this todo from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% todo.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= form.text_field :name, class: "block w-full px-4 py-3 rounded-md border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 border" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= form.textarea :description, rows: 4, class: "block w-full px-4 py-3 rounded-md border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 border" %>
  </div>

  <div class="flex items-center space-x-8">
    <div class="flex items-center">
      <%= form.check_box :completed, class: "h-5 w-5 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
      <%= form.label :completed, class: "ml-2 block text-sm font-semibold text-gray-700" %>
    </div>

    <div class="flex-1">
      <%= form.label :priority, class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= form.number_field :priority, class: "block w-full px-4 py-2 rounded-md border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 border" %>
    </div>
  </div>

  <div>
    <%= form.label :project_id, "Project", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= form.collection_select :project_id, Project.all, :id, :name, { prompt: "Select a project" }, { class: "block w-full px-4 py-3 rounded-md border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 border bg-white" } %>
  </div>
  
  <div class="pt-4">
    <%= form.submit class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-md shadow transition duration-200 cursor-pointer" %>
  </div>
<% end %>
