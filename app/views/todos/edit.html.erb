<div class="max-w-xl mx-auto">
  <div class="mb-6 flex justify-between items-end">
    <div>
      <%= link_to "← Back to Todos", todos_path, class: "text-blue-600 hover:text-blue-800 font-medium mb-2 block" %>
      <h1 class="text-3xl font-extrabold text-gray-900">Edit Todo</h1>
    </div>
    <%= link_to "Show Todo", @todo, class: "text-gray-500 hover:text-gray-700 text-sm font-semibold mb-1" %>
  </div>

  <div class="bg-white shadow-lg rounded-xl p-8 border border-gray-100">
    <%= render "form", todo: @todo %>
  </div>
</div>
