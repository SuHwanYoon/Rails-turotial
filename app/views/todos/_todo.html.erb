<div id="<%= dom_id todo %>">
  <div>
    <strong>Name:</strong>
    <%= todo.name %>
  </div>

  <div>
    <strong>Description:</strong>
    <%= todo.description %>
  </div>


  <div>
    <strong>Completed:</strong>
    <%= todo.completed %>
  </div>

    <div>
    <strong>Priority:</strong>
    <%= todo.priority %>
  </div>

    <div>
    <strong>Project:</strong>
    <%# link_to는 HTML의 `<a>` 태그를 생성하는 Rails의 헬퍼 메서드입니다. %>
    <%# project_path는 rails의 헬퍼메서드 이며 해당 프로젝트의 상세 페이지로 이동하는 링크를 생성합니다.%>
    <%= link_to todo.project.name, project_path(todo.project) %>
  </div>
</div>
