<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold text-gray-800">All Todos</h1>
  <%= link_to "New Todo", new_todo_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded shadow transition duration-200" %>
</div>

<div id="todos" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <% @todos.each do |todo| %>
    <%= render todo %>
  <% end %>
</div>

<% if @todos.empty? %>
  <div class="text-center py-12 bg-white rounded-lg border-2 border-dashed border-gray-300">
    <p class="text-gray-500 text-lg italic">No todos yet.</p>
    <%= link_to "Create your first todo", new_todo_path, class: "text-blue-600 hover:underline font-semibold mt-2 inline-block" %>
  </div>
<% end %>
