    </div>
    <%= link_to "Show Project", @project, class: "text-gray-500 hover:text-gray-700 text-sm font-semibold mb-1" %>
  </div>

  <div class="bg-white shadow-lg rounded-xl p-8 border border-gray-100">
    <%= render "form", project: @project %>
  </div>
</div>
