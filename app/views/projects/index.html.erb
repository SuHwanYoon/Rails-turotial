<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold text-gray-800">Projects</h1>
  <%= link_to "New Project", new_project_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded shadow transition duration-200" %>
</div>

<div class="bg-white shadow overflow-hidden sm:rounded-md">
  <ul class="divide-y divide-gray-200">
    <% @projects.each do |project| %>
      <li>
        <%= link_to project_path(project), class: "block hover:bg-gray-50 transition duration-150 ease-in-out" do %>
          <div class="px-4 py-4 sm:px-6 flex items-center justify-between">
            <div class="text-lg font-medium text-blue-600 truncate">
              <%= project.name %>
            </div>
            <div class="ml-2 flex-shrink-0 flex">
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                <%= pluralize(project.todos.count, 'todo') %>
              </span>
            </div>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
